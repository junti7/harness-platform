# Tier 2 - local LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:27b

# Tier 3 - premium AI
ANTHROPIC_API_KEY=

# Edu DEEP RESEARCH — Semantic Scholar (선택, 없으면 익명 rate limit 적용)
# 무료 API key 발급: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Edu DEEP RESEARCH — YouTube Data API v3 (선택, 설정하면 yt-dlp 대신 공식 API 사용)
# 설정 시: 429 없음, 1만 유닛/일 무료 (채널 5개 × 2회 요청 ≈ 1,100 유닛/실행)
# 발급: Google Cloud Console → API 라이브러리 → YouTube Data API v3 → 사용 설정 → 사용자 인증 정보 → API 키
# 미설정 시: yt-dlp + Chrome 브라우저 쿠키 fallback (Chrome에 YouTube 로그인 필요)
YOUTUBE_API_KEY=

# Tier 4 - publishing
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Slack delivery
# webhook: use SLACK_WEBHOOK_URL or route-specific webhook URLs.
# bot: use SLACK_BOT_TOKEN plus SLACK_CHANNEL_* IDs.
SLACK_DELIVERY_MODE=webhook
SLACK_PHASE=phase1
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

SLACK_CHANNEL_EXEC_PRESIDENT_DECISIONS=
SLACK_CHANNEL_VP_CONTENT_REVIEW=
SLACK_CHANNEL_OPS_INCIDENTS=
# Agentic orchestration Phase 1 channels (Charter §4.2)
SLACK_CHANNEL_TEAM_FRIDAY=
SLACK_CHANNEL_TEAM_KITT=
SLACK_CHANNEL_CONFERENCE_ROOM=
SLACK_CHANNEL_TEAM_VISION=
SLACK_CHANNEL_TEAM_LEDGER=
SLACK_CHANNEL_TEAM_C3PO=
SLACK_CHANNEL_TEAM_COACH=
SLACK_CHANNEL_TEAM_WATCHMAN=
SLACK_CHANNEL_TEAM_SCRIBE=
SLACK_CHANNEL_TEAM_TARS=
# Coupang Partners/Open API
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=
COUPANG_PARTNERS_BASE_URL=https://api-gateway.coupang.com
COUPANG_PARTNERS_PRODUCT_SEARCH_PATH=/v2/providers/affiliate_open_api/apis/openapi/v1/products/search
# Agentic orchestration caps (Charter §5)
ORCHESTRATION_PER_ORDER_COST_LIMIT_USD=2.00
ORCHESTRATION_MAX_CC_HOPS=3

# Cost control
DAILY_COST_LIMIT_USD=1.00

# Business operations
MOBILE_BRIEFING_ENABLED=false
MOBILE_BRIEFING_LIMIT=5
MOBILE_BRIEFING_CHANNEL=text
TRAINING_BRIEFING_ENABLED=false
TRAINING_BRIEFING_CHANNEL=text
TRAINING_REPORT_CADENCE=weekly
CAPITAL_ACTIONS_ENABLED=false

# DB
DATABASE_URL=postgresql://localhost/harness_dev

# Harness-OS dashboard runtime
# Recommended: set a strong random value in local .env and the same value in
# harness-os/frontend/.env (VITE_HARNESS_OS_SECRET).
HARNESS_OS_SECRET_KEY=
HARNESS_CEO_PASSWORD=ceo123
HARNESS_VP_PASSWORD=vp123
HARNESS_OS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
HARNESS_OS_CACHE_SECONDS=60
HARNESS_OS_JARVIS_CHAT_BACKEND=anthropic
HARNESS_OS_JARVIS_CHAT_MODEL=claude-sonnet-4-5
HARNESS_OS_JARVIS_CHAT_MAX_TOKENS=1200
HARNESS_OS_JARVIS_SLACK_DM_CHANNEL_ID=

# IBKR Client Portal API (read-only/trading monitor)
# Official CP Gateway localhost base URL default:
# https://localhost:5000/v1/api
IBKR_CP_API_BASE_URL=https://localhost:5000/v1/api
IBKR_CP_TIMEOUT_S=12
# Keep false only for localhost CP Gateway unless you install a signed cert.
IBKR_CP_TLS_VERIFY=false

# Maily API (발행본 polling 동기화)
# MAILY_API_KEY: maily.so 계정 설정 > API 키 발급
# MAILY_NEWSLETTER_ID: maily.so URL의 newsletter ID (숫자)
MAILY_API_KEY=
MAILY_NEWSLETTER_ID=
MAILY_SYNC_INTERVAL_SEC=900

# Maily metrics source (optional)
# Priority: MAILY_METRICS_CSV_PATH -> MAILY_METRICS_PATH -> MAILY_* env values
MAILY_METRICS_CSV_PATH=
MAILY_METRICS_PATH=
MAILY_FREE_SUBSCRIBERS=
MAILY_PAID_SUBSCRIBERS=
MAILY_PAID_REVENUE_KRW=
MAILY_OPENS=
MAILY_CLICKS=
MAILY_REPLIES=
MAILY_SHARES=
MAILY_UNSUBSCRIBE_COUNT=
MAILY_POST_COUNT=
MAILY_DRAFT_COUNT=
MAILY_METRICS_NOTES=

# Reddit API (무료, 발급: reddit.com/prefs/apps → script 앱 생성)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Naver Search API (무료 25,000 req/일, 발급: developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
