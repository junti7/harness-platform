# Tier 2 - local LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:27b

# Tier 3 - premium AI
ANTHROPIC_API_KEY=

# Tier 4 - publishing
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Slack delivery
# webhook: use SLACK_WEBHOOK_URL or route-specific webhook URLs.
# bot: use SLACK_BOT_TOKEN plus SLACK_CHANNEL_* IDs.
SLACK_DELIVERY_MODE=webhook
SLACK_PHASE=phase1
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

SLACK_CHANNEL_EXEC_PRESIDENT_DECISIONS=
SLACK_CHANNEL_VP_CONTENT_REVIEW=
SLACK_CHANNEL_OPS_INCIDENTS=

# Cost control
DAILY_COST_LIMIT_USD=1.00

# Business operations
MOBILE_BRIEFING_ENABLED=false
MOBILE_BRIEFING_LIMIT=5
MOBILE_BRIEFING_CHANNEL=text
TRAINING_BRIEFING_ENABLED=false
TRAINING_BRIEFING_CHANNEL=text
TRAINING_REPORT_CADENCE=weekly
CAPITAL_ACTIONS_ENABLED=false

# DB
DATABASE_URL=postgresql://localhost/harness_dev
