#!/usr/bin/env bash
# Harness 공유 pre-push 훅 — origin push 불변식을 기계적으로 강제한다.
#
# 왜: 운영 규칙(SSH-only remote 등)을 LLM/사람이 "기억"으로 지키는 건 신뢰할 수 없다.
#     어기는 게 물리적으로 막히게 한다. (docs/governance/LLM_GROUND_RULES.md)
#
# 적용: 이 훅은 repo의 .githooks/ 에 버전관리되며, scripts/install_git_hooks.sh 가
#       `git config core.hooksPath .githooks` 로 활성화한다(머신마다 1회).
#
# 주의: git push --no-verify 로 우회 가능하다(훅의 한계). 자동 잡의 진짜 가드는
#       스크립트 preflight(예: sync_decision_records.py 의 SSH assert)다. 훅은 사람/대화형
#       실수를 잡는 1차 방어선.
#
# 인자: $1=remote name, $2=remote URL. push 대상 ref 는 stdin.
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

# remote URL 이 인자로 안 올 때(일부 git 버전) 보강. push URL 은 fetch URL 과 다를 수 있으므로
# 반드시 --push 로 조회한다(push 가 실제로 쓰는 URL 을 검사).
if [ -z "$remote_url" ] && [ -n "$remote_name" ]; then
  remote_url="$(git remote get-url --push "$remote_name" 2>/dev/null || true)"
fi

# [규칙 1] push URL 은 SSH(git@... 또는 ssh://...) 여야 한다. HTTPS 면 무인 push 가 비대화형에서
#          실패하거나 자격증명 프롬프트로 멈춘다(2026-06-12 Mac Mini 사고).
#   blacklist(https://github.com/*) 는 우회됨(auth-embedded `https://x-access-token@github.com/...`,
#   대문자 스킴 `HTTPS://...`). 그래서 SSH 형식만 허용하는 allowlist 로 검사한다.
if [ -n "$remote_url" ]; then
  shopt -s nocasematch 2>/dev/null || true   # 대문자 스킴(SSH://, GIT@)도 포착
  case "$remote_url" in
    git@*|ssh://*) : ;;   # 허용(SSH)
    *)
      echo "✖ [pre-push 차단] push URL 이 SSH 가 아닙니다: $remote_url" >&2
      echo "  Harness 규칙: GitHub remote 는 SSH(git@github.com:...) 여야 push 가능합니다(무인 잡 포함)." >&2
      echo "  수정: git remote set-url $remote_name git@github.com:junti7/harness-platform.git" >&2
      echo "  근거: docs/governance/LLM_GROUND_RULES.md / DEPLOYMENT_SOURCE_OF_TRUTH.md" >&2
      exit 1
      ;;
  esac
  shopt -u nocasematch 2>/dev/null || true
fi

# [규칙 2] main 으로의 force-push 금지(공유 히스토리 보호).
# [규칙 3] 프론트 빌드 입력 변경 감지 → 배포 시 dist 재빌드 리마인더(비차단).
#   프로덕션 프론트는 빌드된 dist 를 serve 가 서빙하므로 push 만으로는 화면에 반영되지 않는다.
#   push 자체는 정상 흐름(push→deploy)이라 차단하지 않고, 누락하기 쉬운 "재빌드 배포"를 환기한다.
#   진짜 하드 가드는 Mac Mini 08:00 check_code_drift.py 의 dist STALE 감지(exit 1 + Slack)다.
protected_ref="refs/heads/main"
fe_changed=0
changed_files_tmp="$(mktemp)"
trap 'rm -f "$changed_files_tmp"' EXIT
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$remote_ref" = "$protected_ref" ] || continue
  # 삭제 push 차단
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    echo "✖ [pre-push 차단] origin/main 삭제 push 는 금지입니다." >&2
    exit 1
  fi
  # non-fast-forward(force) 차단: 원격 tip 이 로컬 조상이 아니면 거절.
  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "✖ [pre-push 차단] origin/main 으로의 non-fast-forward(force) push 금지." >&2
      echo "  먼저 git fetch 후 ff 로 정렬하세요(공유 히스토리 보호)." >&2
      exit 1
    fi
    # 규칙 3: 이 push 범위에 프론트 빌드 입력 변경이 있는지
    git diff --name-only "$remote_sha..$local_sha" 2>/dev/null >> "$changed_files_tmp" || true
    if grep -qE '^harness-os/frontend/(src/|public/|index\.html|package\.json|vite\.config\.)' "$changed_files_tmp"; then
      fe_changed=1
    fi
  fi
done

if [ "$fe_changed" = "1" ]; then
  echo "────────────────────────────────────────────────────────────" >&2
  echo "⚠ [pre-push] 프론트 소스 변경이 포함된 push 입니다(차단 아님)." >&2
  echo "  프로덕션 프론트 = 빌드된 dist 를 serve 가 서빙 → push 만으로는 화면 미반영." >&2
  echo "  필수: scripts/deploy_to_macmini.sh <변경된 harness-os/frontend 경로> 로 배포(자동 dist 재빌드)." >&2
  echo "  미수행 시 Mac Mini 08:00 드리프트 가드가 'dist STALE' 로 경보합니다." >&2
  echo "────────────────────────────────────────────────────────────" >&2
fi

# [규칙 4] LLM/agent code·governance 변경은 completion evidence 없이 main 으로 push 금지.
# 왜: "규칙을 읽었다/검증했다"는 자연어 보고는 반복적으로 실패했다. 그래서 변경 push 자체에
#     docs/reports/completion_evidence/*.json + scripts/agent_completion_guard.py 통과를 요구한다.
# 한계: git push --no-verify 로 우회 가능하다. 그래도 일반 LLM/사람 push 경로의 1차 물리 방어선이다.
if [ -s "$changed_files_tmp" ]; then
  if grep -qE '^(core/openclaw_response_quality\.py|adapters/content/(openclaw_agent|outbound_delivery|slack_listener)\.py|scripts/(generate_openclaw_quality_corpus|score_openclaw_response_quality|score_openclaw_shadow_quality)\.py|configs/openclaw/response_quality_corpus_v1\.jsonl|tests/test_openclaw_(agent|response_quality|slack_e2e_probe)\.py|tests/test_slack_listener\.py)$' "$changed_files_tmp"; then
    echo "▶ [pre-push] OpenClaw response-quality hard gate" >&2
    .venv/bin/python scripts/score_openclaw_response_quality.py \
      --corpus configs/openclaw/response_quality_corpus_v1.jsonl \
      --min-cases 240 \
      --output runtime/openclaw_quality_eval.json >&2
    .venv/bin/python scripts/score_openclaw_e2e_golden.py \
      --corpus configs/openclaw/e2e_golden_corpus_v1.jsonl \
      --output runtime/openclaw_e2e_golden.json >&2
    .venv/bin/python -m pytest \
      tests/test_openclaw_response_quality.py \
      tests/test_openclaw_agent.py \
      tests/test_slack_listener.py \
      tests/test_openclaw_slack_e2e_probe.py -q >&2
  fi

  if grep -qE '^(harness-os/|core/|scripts/|configs/|adapters/|tests/|CLAUDE\.md|AGENTS\.md|GEMINI\.md|\.github/copilot-instructions\.md|docs/governance/)' "$changed_files_tmp" \
     && ! grep -qE '^docs/reports/completion_evidence/[^/]+\.json$' "$changed_files_tmp"; then
    echo "✖ [pre-push 차단] code/governance 변경에는 completion evidence JSON 이 필요합니다." >&2
    echo "  요구 경로: docs/reports/completion_evidence/<task-or-commit>.json" >&2
    echo "  검증: scripts/agent_completion_guard.py <json>" >&2
    echo "  근거: docs/governance/LLM_GROUND_RULES.md §2.8" >&2
    exit 1
  fi

  evidence_ok=0
  while read -r evidence_path; do
    [ -n "$evidence_path" ] || continue
    if [ -f "$evidence_path" ] && scripts/agent_completion_guard.py "$evidence_path" >/tmp/harness_completion_guard_pre_push.log 2>&1; then
      evidence_ok=1
      break
    fi
  done < <(grep -E '^docs/reports/completion_evidence/[^/]+\.json$' "$changed_files_tmp" || true)
  if grep -qE '^docs/reports/completion_evidence/[^/]+\.json$' "$changed_files_tmp" && [ "$evidence_ok" != "1" ]; then
    echo "✖ [pre-push 차단] completion evidence JSON 이 guard 를 통과하지 못했습니다." >&2
    cat /tmp/harness_completion_guard_pre_push.log >&2 2>/dev/null || true
    exit 1
  fi
fi

exit 0
