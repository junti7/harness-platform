<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.harness.edu-tier3-free</string>

  <key>ProgramArguments</key>
  <array>
    <string>__ROOT__/.venv/bin/python3</string>
    <string>__ROOT__/scripts/run_edu_tier3_parallel.py</string>
    <string>--free-tier</string>
    <string>--limit</string>
    <string>10</string>
    <string>--triage-limit</string>
    <string>50</string>
    <string>--cost-every</string>
    <string>10</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__ROOT__</string>

  <!-- Conservative free-tier backlog drain: rule-skip obvious noise first, then Gemini-refine up to 10 keep candidates. Workers are capped to 2 by the script. -->
  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__ROOT__/logs/edu-tier3-free.log</string>
  <key>StandardErrorPath</key>
  <string>__ROOT__/logs/edu-tier3-free.error.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>DATABASE_URL</key>
    <string>postgresql://localhost/harness_prod</string>
  </dict>
</dict>
</plist>
