<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.harness.ibkr-watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>__ROOT__/.venv/bin/python3</string>
    <string>__ROOT__/scripts/pipeline_watchdog.py</string>
    <string>--ibkr-only</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__ROOT__</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>__ROOT__/logs/ibkr-watchdog.log</string>

  <key>StandardErrorPath</key>
  <string>__ROOT__/logs/ibkr-watchdog.error.log</string>
</dict>
</plist>
