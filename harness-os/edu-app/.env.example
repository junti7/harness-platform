# Harness edu-app (VP 훈련 pilot) 환경변수 예시.
# 실제 값은 .env(.gitignore 처리)에 둔다. secret 을 커밋하지 않는다.

# 백엔드 API base. dev 에서는 비워두면 vite proxy(/api → :8000)를 탄다.
VITE_HARNESS_OS_API_BASE=

# secret 티어(vp-training) 호출용. 콘솔과 동일한 X-Harness-Secret 값.
# 주의: 빌드 번들에 포함되므로 이 앱은 접근 제어 전제(완전 공개 금지).
VITE_HARNESS_SECRET=
